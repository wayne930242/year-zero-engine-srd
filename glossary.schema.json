{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/schemas/glossary.schema.json",
  "title": "Game Terminology Glossary",
  "type": "object",
  "required": ["_meta"],
  "properties": {
    "_meta": {
      "type": "object",
      "required": ["description", "updated"],
      "properties": {
        "description": { "type": "string" },
        "updated": { "type": "string" }
      },
      "additionalProperties": true
    }
  },
  "patternProperties": {
    "^(?!_meta$).+": {
      "type": "object",
      "properties": {
        "zh": { "type": "string" },
        "notes": { "type": "string" },
        "status": {
          "type": "string",
          "enum": ["approved", "candidate", "deprecated"]
        },
        "is_term": { "type": "boolean" },
        "keep_english": { "type": "boolean" },
        "forbidden": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 }
        }
      },
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "status": { "const": "approved" }
            },
            "required": ["status"]
          },
          "then": {
            "required": ["zh"]
          }
        }
      ]
    }
  },
  "additionalProperties": false
}
